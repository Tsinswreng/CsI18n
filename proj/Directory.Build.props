		<PackageReference Include="Tsinswreng.CsCfg" Version="0.0.1-alpha" />
		<PackageReference Include="Tsinswreng.CsErr" Version="0.0.1-alpha" />
		<!-- <ProjectReference Include="../../../Tsinswreng.CsCfg/proj/Tsinswreng.CsCfg/Tsinswreng.CsCfg.csproj" /> -->
		<!-- <ProjectReference Include="../../../Tsinswreng.CsErr/proj/Tsinswreng.CsErr/Tsinswreng.CsErr.csproj" /> -->
		<!-- <ProjectReference Include="../../../Tsinswreng.CsCore/proj/Tsinswreng.CsCore/Tsinswreng.CsCore.csproj" /> -->
		
		<PackageReference Include="MessageFormat" Version="7.1.3" />
	</ItemGroup>

</Project>
